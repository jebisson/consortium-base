---
import { tenant } from "../config/tenant";
import { t } from "../i18n/utils";

interface Props {
  lang: string;
  serviceName: string;
  serviceType?: string;
  contactSource?: string;
  formId?: string;
  containerId?: string;
  statusId?: string;
  openBtnId?: string;
  closeBtnId?: string;
  formTitle?: string;
  submitLabel?: string;
  closeLabel?: string;
}

const {
  lang,
  serviceName,
  serviceType = "TI",
  contactSource,
  formId = "serviceForm",
  containerId = "serviceFormContainer",
  statusId = "serviceFormStatus",
  openBtnId = "openFormBtn",
  closeBtnId = "closeFormBtn",
  formTitle,
  submitLabel,
  closeLabel,
} = Astro.props;

const tr = t(lang);
const common = tr.common;
const consentText = tenant.consent[lang as 'fr' | 'en'];
const finalSubmitLabel = submitLabel ?? common.sendRequest;
const finalCloseLabel = closeLabel ?? common.close;
---

<div id={containerId} class="overflow-hidden max-h-0 opacity-0 transition-all duration-500">
  <div class="rounded-2xl p-6 md:p-7" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.10);">

    {formTitle && (
      <div class="flex items-center justify-between gap-4 mb-4">
        <h3 class="text-xl font-semibold soft">{formTitle}</h3>
        <button data-close-panel={containerId} type="button"
                class="px-3 py-2 rounded-lg card-icon muted hover:brightness-110 focus-ring text-sm">
          {finalCloseLabel}
        </button>
      </div>
    )}

    <form id={formId} class="space-y-4" style="background: rgba(255,255,255,0.05); border-radius: 0.75rem; padding: 1.5rem; border: 1px solid rgba(255,255,255,0.08);">
      <input type="hidden" name="service_type" value={serviceType} />
      <input type="hidden" name="service_name" value={serviceName} />
      {contactSource && <input type="hidden" name="contact_source" value={contactSource} />}

      {tenant.id !== 'eesad' && (
        <>
          <div>
            <p class="text-sm font-semibold mb-2 soft">{common.memberQuestion} <span class="text-rose-400">*</span></p>
            <div class="flex flex-wrap gap-6 text-sm soft">
              <label class="flex items-center gap-2"><input type="radio" name="is_member" value="oui" required style="accent-color: var(--accent);" /> {common.yes}</label>
              <label class="flex items-center gap-2"><input type="radio" name="is_member" value="non" style="accent-color: var(--accent);" /> {common.no}</label>
              <label class="flex items-center gap-2"><input type="radio" name="is_member" value="ne_sais_pas" style="accent-color: var(--accent);" /> {common.dontKnow}</label>
            </div>
          </div>
          <div>
            <p class="text-sm font-semibold mb-2 soft">{common.federationQuestion} <span class="text-rose-400">*</span></p>
            <div class="flex flex-wrap gap-6 text-sm soft">
              <label class="flex items-center gap-2"><input type="radio" name="is_federation" value="oui" required style="accent-color: var(--accent);" /> {common.yes}</label>
              <label class="flex items-center gap-2"><input type="radio" name="is_federation" value="non" style="accent-color: var(--accent);" /> {common.no}</label>
              <label class="flex items-center gap-2"><input type="radio" name="is_federation" value="ne_sais_pas" style="accent-color: var(--accent);" /> {common.dontKnow}</label>
            </div>
          </div>
          <div>
            <p class="text-sm font-semibold mb-2 soft">{common.companyTypeQuestion} <span class="text-rose-400">*</span></p>
            <div class="flex flex-wrap gap-6 text-sm soft">
              <label class="flex items-center gap-2"><input type="radio" name="company_type" value="cooperative" required style="accent-color: var(--accent);" /> {common.cooperative}</label>
              <label class="flex items-center gap-2"><input type="radio" name="company_type" value="mutuelle" style="accent-color: var(--accent);" /> {common.mutuelle}</label>
              <label class="flex items-center gap-2"><input type="radio" name="company_type" value="obnl" style="accent-color: var(--accent);" /> {common.obnl}</label>
              <label class="flex items-center gap-2"><input type="radio" name="company_type" value="autre" style="accent-color: var(--accent);" /> {common.other}</label>
            </div>
          </div>
        </>
      )}

      <!-- Nom de l'entreprise -->
      <div>
        <label class="block text-sm font-semibold mb-1 soft">{common.companyName} <span class="text-rose-400">*</span></label>
        <input type="text" name="company_name" required
               class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
               style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
      </div>

      <!-- Adresse -->
      <div>
        <label class="block text-sm font-semibold mb-1 soft">{common.address} <span class="text-rose-400">*</span></label>
        <input type="text" name="street_address" required placeholder={common.streetAddress}
               class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm mb-1"
               style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
        <p class="text-xs mb-2 muted">{common.streetAddress}</p>
        <div class="grid grid-cols-2 gap-3 mb-1">
          <div>
            <input type="text" name="city" required
                   class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                   style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
            <p class="text-xs mt-1 muted">{common.city}</p>
          </div>
          <div>
            <select name="province" required
                    class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                    style="background: #1e2535; border: 1px solid rgba(255,255,255,0.12); color: var(--text);">
              <option style="background:#1e2535;color:#e5e7eb;" selected>Québec</option>
              <option style="background:#1e2535;color:#e5e7eb;">Ontario</option>
              <option style="background:#1e2535;color:#e5e7eb;">Colombie-Britannique</option>
              <option style="background:#1e2535;color:#e5e7eb;">Alberta</option>
              <option style="background:#1e2535;color:#e5e7eb;">Manitoba</option>
              <option style="background:#1e2535;color:#e5e7eb;">Saskatchewan</option>
              <option style="background:#1e2535;color:#e5e7eb;">Nouvelle-Écosse</option>
              <option style="background:#1e2535;color:#e5e7eb;">Nouveau-Brunswick</option>
              <option style="background:#1e2535;color:#e5e7eb;">Terre-Neuve-et-Labrador</option>
              <option style="background:#1e2535;color:#e5e7eb;">Île-du-Prince-Édouard</option>
            </select>
            <p class="text-xs mt-1 muted">{common.province}</p>
          </div>
        </div>
        <div style="max-width: 50%; display: block;">
          <input type="text" name="postal_code" required
                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
          <p class="text-xs mt-1 muted">{common.postalCode}</p>
        </div>
      </div>

      <!-- Personne contact + Titre -->
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-semibold mb-1 soft">{common.contactPerson} <span class="text-rose-400">*</span></label>
          <input type="text" name="contact_person" required
                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1 soft">{common.contactTitle}</label>
          <input type="text" name="contact_title"
                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
        </div>
      </div>

      <!-- Courriel + Téléphone -->
      <div class="grid grid-cols-2 gap-3">
        <div>
          <label class="block text-sm font-semibold mb-1 soft">{common.email} <span class="text-rose-400">*</span></label>
          <input type="email" name="contact_email" required
                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
        </div>
        <div>
          <label class="block text-sm font-semibold mb-1 soft">{common.phone}</label>
          <input type="tel" name="contact_phone"
                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
        </div>
      </div>

      <!-- Service-specific fields -->
      <slot />

      <!-- Message -->
      <div>
        <label class="block text-sm font-semibold mb-1 soft">{common.message}</label>
        <textarea name="contact_message" rows="4"
                  class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm resize-none"
                  style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);"></textarea>
      </div>

      <!-- Consentement -->
      <label class="flex items-start gap-2.5 cursor-pointer">
        <input type="checkbox" required name="consent"
               class="mt-0.5 h-4 w-4 shrink-0 rounded focus-ring"
               style="accent-color: var(--accent);" />
        <span class="text-xs muted">{consentText}</span>
      </label>

      <button type="submit"
              class="w-full px-4 py-3 rounded-xl font-semibold transition hover:brightness-110"
              style="background: var(--accent); color: #111;">
        {finalSubmitLabel}
      </button>

      <button data-close-panel={containerId} type="button"
              class="mt-2 w-full px-4 py-2 rounded-xl font-medium border transition hover:brightness-110"
              style="background: rgba(255,255,255,0.06); border-color: rgba(255,255,255,0.12); color: var(--text);">
        {finalCloseLabel}
      </button>

      <p id={statusId} class="text-sm mt-2 soft"></p>
    </form>
  </div>
</div>

<script define:vars={{
  formId, containerId, statusId, openBtnId,
  msgSending: common.sending,
  msgDone: common.sent,
  msgError: common.errorSend,
  msgNetwork: common.errorNetwork,
}}>
  const panel  = document.getElementById(containerId);
  const form   = document.getElementById(formId);
  const status = document.getElementById(statusId);

  function openPanel() {
    if (!panel) return;
    panel.style.maxHeight = panel.scrollHeight + "px";
    panel.style.opacity = "1";
    panel.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }
  function closePanel() {
    if (!panel) return;
    panel.style.maxHeight = "0";
    panel.style.opacity = "0";
  }

  document.getElementById(openBtnId)?.addEventListener("click", openPanel);

  document.querySelectorAll(`[data-close-panel="${containerId}"]`).forEach(btn =>
    btn.addEventListener("click", closePanel)
  );

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const data = {};
    for (const [k, v] of new FormData(form).entries()) data[k] = v;
    if (status) status.textContent = msgSending;
    try {
      const res = await fetch("/api/submit", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(data),
      });
      if (status) status.textContent = res.ok ? msgDone : msgError;
      if (res.ok) form.reset();
    } catch {
      if (status) status.textContent = msgNetwork;
    }
  });
</script>
