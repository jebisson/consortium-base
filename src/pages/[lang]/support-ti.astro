---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { t } from "../../i18n/utils";
import { tenant } from "../../config/tenant";
import ServiceForm from "../../components/ServiceForm.astro";

export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "fr" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: string };
const tr = t(lang);
const s = tr.support;
const currentPath = `/${lang}/support-ti`;
---

<SiteLayout title={s.title} description={s.heroDesc} lang={lang} currentPath={currentPath}>
  <style>
    .card-dark {
      background: var(--card);
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow: 0 20px 40px rgba(0,0,0,0.45), 0 4px 12px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.07);
      border-radius: 1rem;
    }
    .hover-tint {
      background: radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 62%);
      position: absolute; inset: 0; pointer-events: none; opacity: 0.70; transition: opacity 0.3s;
    }
    .band-title { color: rgba(17,17,17,0.92); }
    .band-soft  { color: rgba(17,17,17,0.75); }
    .band-muted { color: rgba(17,17,17,0.62); }
    .icon-accent { color: var(--accent); }
    .card-icon { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); }
    .focus-ring:focus { outline: none; box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 30%, transparent); }
    .pill { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); color: color-mix(in srgb, var(--text) 92%, transparent); }
  </style>

  <!-- HEADER -->
  <div slot="header" class="flex flex-col items-center">
    <img src={tenant.logoSrc} alt={tenant.name} class="h-28 md:h-36 w-auto drop-shadow-lg" />
    <p class="mt-3 text-xs tracking-[0.35em] uppercase"
       style="color: color-mix(in srgb, var(--text) 55%, transparent);">{s.headerSubtitle}</p>
  </div>

  <!-- HERO -->
  <div slot="hero" class="relative max-w-4xl mx-auto px-4 text-center z-20 pt-2 pb-10">
    <div class="pointer-events-none absolute left-1/2 top-8 -translate-x-1/2 w-[65%] h-24 blur-[80px] opacity-60"
         style="background: color-mix(in srgb, var(--accent) 20%, transparent);"></div>
    <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight animate-fade-up" style="color: var(--text);">
      {s.heroTitle}
    </h1>
    <p class="mt-4 text-lg soft animate-fade-up animate-fade-up-delay-1 max-w-2xl mx-auto">{s.heroDesc}</p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center animate-fade-up animate-fade-up-delay-2">
      <a href="#forfaits"
         class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold transition hover:brightness-110 active:scale-95"
         style="background: var(--accent); color: #111; box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 30%, transparent);">
        {lang === "fr" ? "Voir les forfaits" : "View plans"}
      </a>
    </div>
    <div class="mt-8 flex flex-wrap gap-2 justify-center animate-fade-up animate-fade-up-delay-3">
      {s.heroTags.map((tag) => <span class="pill px-4 py-2 rounded-full text-sm">{tag}</span>)}
    </div>
  </div>

  <!-- BAND -->
  <section class="relative w-full overflow-hidden" style="background: var(--band);">
    <div class="h-[2px] w-full" style="background: var(--accent);"></div>
    <div class="h-12 w-full"
         style="background: linear-gradient(to bottom, color-mix(in srgb, var(--accent) 16%, transparent), transparent);"></div>

    <div class="relative z-10">
      <main class="mx-auto max-w-6xl px-4 pb-20 pt-10 space-y-14">

        <!-- FEATURES -->
        <section>
          <div class="rounded-3xl bg-white p-8 md:p-10 shadow-xl border border-black/10 reveal">
            <h2 class="text-3xl font-semibold band-title">{s.featuresTitle}</h2>
            <p class="mt-3 text-lg band-soft max-w-3xl">{s.featuresDesc}</p>
            <div class="mt-8 grid gap-4 md:grid-cols-3">
              {s.features.map((f, i) => (
                <div class="rounded-2xl p-6 border border-black/10 reveal">
                  <div class="flex items-start gap-3">
                    <div class="h-11 w-11 rounded-xl card-icon flex items-center justify-center shrink-0">
                      {i === 0 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>}
                      {i === 1 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 01-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0115 18.257V17.25m6-12V15a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 15V5.25m18 0A2.25 2.25 0 0018.75 3H5.25A2.25 2.25 0 003 5.25m18 0H3"/></svg>}
                      {i === 2 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z"/></svg>}
                      {i === 3 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 002.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 00-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 00.75-.75 2.25 2.25 0 00-.1-.664m-5.8 0A2.251 2.251 0 0113.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25z"/></svg>}
                      {i === 4 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z"/></svg>}
                      {i === 5 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 001.5-.189m-1.5.189a6.01 6.01 0 01-1.5-.189m3.75 7.478a12.06 12.06 0 01-4.5 0m3.75 2.383a14.406 14.406 0 01-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 10-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/></svg>}
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold band-title">{f.title}</h3>
                      <p class="mt-1 band-muted">{f.desc}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- PLANS -->
        <section id="forfaits">
          <h2 class="text-3xl font-semibold reveal" style="color: black;">{s.plansTitle}</h2>
          <p class="mt-2 max-w-3xl reveal" style="color: rgba(17,17,17,0.70);">{s.plansDesc}</p>
          <div class="mt-7 grid gap-6 md:grid-cols-3">
            {s.plans.map((plan) => (
              <div class="rounded-2xl p-6 card-dark overflow-hidden relative reveal">
                <div class="hover-tint"></div>
                <div class="relative">
                  <div class="flex items-baseline gap-2 mb-1">
                    <span class="text-3xl font-bold" style="color: var(--accent);">{plan.hours}</span>
                  </div>
                  <p class="muted text-sm">{plan.subtitle}</p>
                  <ul class="mt-5 space-y-2">
                    {plan.bullets.map((b) => (
                      <li class="flex items-center gap-2 text-sm soft">
                        <svg class="h-4 w-4 shrink-0 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5"/>
                        </svg>
                        {b}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
          <p class="mt-4 text-sm italic" style="color: rgba(17,17,17,0.55);">{s.priceNote}</p>
        </section>

        <!-- CTA + FORM -->
        <section id="demande" class="pb-6">
          <div class="rounded-3xl p-8 md:p-10 card-dark overflow-hidden relative reveal">
            <div class="hover-tint" style="opacity: 0.60;"></div>
            <div class="pointer-events-none absolute -top-20 -left-20 h-52 w-52 rounded-full blur-3xl opacity-25" style="background: var(--accent);"></div>
            <div class="pointer-events-none absolute -bottom-20 -right-20 h-52 w-52 rounded-full blur-3xl opacity-15" style="background: var(--accent);"></div>

            <div class="relative flex flex-col gap-8">
              <div>
                <h2 class="text-3xl font-semibold soft">{s.ctaTitle}</h2>
                <p class="mt-2 muted">{s.ctaDesc}</p>
                <div class="mt-6">
                  <button id="openFormBtn" type="button"
                          class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold transition hover:brightness-110 focus-ring"
                          style="background: var(--accent); color: #111; box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 30%, transparent);">
                    {s.ctaOpenBtn}
                  </button>
                </div>
              </div>

              <ServiceForm
                lang={lang}
                serviceName="Support TI"
                formId="supportForm"
                containerId="formContainer"
                statusId="supportStatus"
                openBtnId="openFormBtn"
                formTitle={s.formTitle}
                closeLabel={s.formCloseBtn}
              >
                <div>
                  <label class="block text-sm font-semibold mb-1 soft">{s.formPlanLabel} <span class="text-rose-400">*</span></label>
                  <select name="support_plan" required
                          class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                          style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);">
                    {s.formPlans.map((p) => (
                      <option value={p.value}>{p.label}</option>
                    ))}
                  </select>
                </div>
              </ServiceForm>
            </div>
          </div>
        </section>

      </main>
    </div>
  </section>
</SiteLayout>
