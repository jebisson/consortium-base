---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { tenant } from "../../../config/tenant";
import { getCollection, render } from "astro:content";

export const prerender = true;
export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { lang: post.data.lang ?? "fr", slug: post.data.url_slug },
    props: { post },
  }));
}

const { lang } = Astro.params as { lang: string };
const { post } = Astro.props;
const { Content, headings } = await render(post);

const currentPath = `/${lang}/blog/${post.data.url_slug}`;
const readingMinutes = Math.ceil((post.data.mots ?? 800) / 200);
const h2Headings = headings.filter((h) => h.depth === 2);

const dateObj = post.data.date ? new Date(post.data.date + "T12:00:00") : new Date();
const dateFormatted = dateObj.toLocaleDateString(lang === "fr" ? "fr-CA" : "en-CA", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.meta_description,
  url: `${tenant.siteUrl}${currentPath}`,
  inLanguage: lang === "fr" ? "fr-CA" : "en-CA",
  datePublished: post.data.date ?? "2026-04-27",
  dateModified: post.data.date ?? "2026-04-27",
  publisher: {
    "@type": "Organization",
    name: tenant.name,
    url: tenant.siteUrl,
    logo: { "@type": "ImageObject", url: `${tenant.siteUrl}${tenant.logoSrc}` },
  },
  author: { "@type": "Organization", name: tenant.name, url: tenant.siteUrl },
};
---

<SiteLayout
  title={post.data.title}
  description={post.data.meta_description}
  lang={lang}
  currentPath={currentPath}
>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,600;9..40,700&display=swap"
    />
  </Fragment>

  <!-- HEADER -->
  <div slot="header" class="flex flex-col items-center">
    <img
      src={tenant.logoSrc}
      alt={tenant.name}
      class="h-28 md:h-36 w-auto drop-shadow-lg"
      fetchpriority="high"
      loading="eager"
    />
    <p
      class="mt-3 text-xs tracking-[0.35em] uppercase"
      style="color: color-mix(in srgb, var(--text) 55%, transparent); font-family: 'DM Sans', sans-serif;"
    >
      <a href={`/${lang}/blog`} style="color: inherit; text-decoration: none;">
        {lang === "fr" ? "← Blogue TI" : "← IT Blog"}
      </a>
    </p>
  </div>

  <!-- HERO -->
  <div slot="hero" class="relative max-w-3xl mx-auto px-4 text-center z-20 pt-2 pb-10">
    <div
      class="pointer-events-none absolute left-1/2 top-8 -translate-x-1/2 w-[60%] h-20 blur-[70px] opacity-50"
      style="background: color-mix(in srgb, var(--accent) 20%, transparent);"
    ></div>
    <div class="mt-4 animate-fade-up">
      <span
        style="display:inline-block;font-size:0.7rem;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:4px 14px;border-radius:999px;color:#fff;background:var(--accent);font-family:'DM Sans',sans-serif;"
      >{post.data.angle}</span>
    </div>
    <h1
      class="mt-4 text-3xl md:text-4xl font-bold tracking-tight animate-fade-up leading-tight"
      style="color: var(--text); font-family: 'DM Sans', sans-serif;"
    >
      {post.data.title}
    </h1>
    <p
      class="mt-4 text-base animate-fade-up max-w-2xl mx-auto"
      style="color: color-mix(in srgb, var(--text) 72%, transparent); font-family: 'DM Sans', sans-serif;"
    >{post.data.meta_description}</p>
  </div>

  <!-- READING PROGRESS BAR -->
  <div id="progress-bar"></div>

  <!-- ARTICLE META BAR -->
  <div class="article-meta-bar">
    <span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
      <strong>{dateFormatted}</strong>
    </span>
    <span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
      <strong>{readingMinutes} min</strong> {lang === "fr" ? "de lecture" : "read"}
    </span>
    <span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      <strong>{tenant.name}</strong>
    </span>
  </div>

  <!-- ARTICLE LAYOUT -->
  <div class="article-outer">
    <div class="article-wrap">

      <!-- MAIN BODY -->
      <article class="article-body" id="article">
        <div class="prose-content">
          <Content />
        </div>

        <!-- TAGS -->
        <div class="article-tags">
          <span class="tag">{post.data.angle}</span>
          <span class="tag">{lang === "fr" ? "Coopératives & OBNL" : "Co-ops & Non-profits"}</span>
          <span class="tag">{lang === "fr" ? "TI Québec" : "Quebec IT"}</span>
        </div>

        <!-- END CTA -->
        <div class="article-cta">
          <h3>{lang === "fr" ? "Votre organisation est-elle bien protégée ?" : "Is your organization well protected?"}</h3>
          <p>{lang === "fr" ? "Nous proposons un diagnostic TI adapté aux coopératives et OBNL du Québec. Sans engagement." : "We offer an IT diagnostic tailored for Quebec co-ops and non-profits. No commitment."}</p>
          <a href={post.data.cta_principal} class="btn-gold">
            {lang === "fr" ? "Demander une soumission →" : "Get a quote →"}
          </a>
        </div>
      </article>

      <!-- SIDEBAR -->
      <aside class="sidebar">

        {h2Headings.length > 0 && (
          <nav class="toc">
            <div class="toc-label">{lang === "fr" ? "Dans cet article" : "In this article"}</div>
            <ul class="toc-list" id="toc-list">
              {h2Headings.map((h) => (
                <li>
                  <a href={`#${h.slug}`} data-target={h.slug}>{h.text}</a>
                </li>
              ))}
            </ul>
          </nav>
        )}

        <div class="sidebar-card">
          <h4>{lang === "fr" ? "Diagnostic TI gratuit" : "Free IT Diagnostic"}</h4>
          <p>{lang === "fr" ? "45 minutes. Sans engagement. Spécialisé pour les organisations collectives du Québec." : "45 minutes. No commitment. Specialized for Quebec collective organizations."}</p>
          <a href={`/${lang}/contact`} class="btn-dark">
            {lang === "fr" ? "Réserver une rencontre" : "Book a meeting"}
          </a>
        </div>

        <div class="sidebar-share">
          <div class="sidebar-share-label">{lang === "fr" ? "Partager" : "Share"}</div>
          <div class="share-btns">
            <a
              href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(tenant.siteUrl + currentPath)}`}
              target="_blank"
              rel="noopener"
              class="share-btn"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="#0A66C2"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.63-1.85 3.35-1.85 3.58 0 4.24 2.36 4.24 5.43v6.31zM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12zM7.12 20.45H3.55V9h3.57v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0z"/></svg>
              LinkedIn
            </a>
            <button class="share-btn" id="copy-link-btn">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              {lang === "fr" ? "Copier" : "Copy"}
            </button>
          </div>
        </div>

        <a href={`/${lang}/blog`} class="back-link">
          ← {lang === "fr" ? "Retour au blogue" : "Back to blog"}
        </a>

      </aside>
    </div>
  </div>

  <style is:global>
    #progress-bar {
      position: fixed;
      top: 0; left: 0;
      height: 3px;
      width: 0%;
      background: var(--accent);
      z-index: 1000;
      transition: width 0.1s linear;
    }

    .article-meta-bar {
      background: #1e1e18;
      color: rgba(255,255,255,0.55);
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 13px;
      display: flex;
      justify-content: center;
      align-items: center;
      gap: 24px;
      padding: 14px 24px;
      flex-wrap: wrap;
    }
    .article-meta-bar span { display: flex; align-items: center; gap: 6px; }
    .article-meta-bar strong { color: rgba(255,255,255,0.9); }

    .article-outer {
      background: #F6F0E4;
      padding: 56px 24px 96px;
      font-family: 'DM Sans', system-ui, sans-serif;
    }

    .article-wrap {
      max-width: 1100px;
      margin: 0 auto;
      display: grid;
      grid-template-columns: 1fr 280px;
      gap: 56px;
      align-items: start;
    }

    .article-body { min-width: 0; }

    .prose-content {
      font-family: 'Lora', Georgia, serif;
    }
    .prose-content p {
      font-size: 18px;
      line-height: 1.8;
      color: #1C1B16;
      margin-bottom: 1.5em;
    }
    .prose-content h2 {
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 26px;
      font-weight: 700;
      color: #141410;
      margin: 2.5em 0 0.75em;
      letter-spacing: -0.02em;
      padding-left: 16px;
      border-left: 3px solid var(--accent);
      line-height: 1.25;
    }
    .prose-content h3 {
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 18px;
      font-weight: 600;
      color: #141410;
      margin: 2em 0 0.5em;
      letter-spacing: -0.01em;
    }
    .prose-content ul,
    .prose-content ol {
      margin-bottom: 1.5em;
      padding-left: 1.5rem;
    }
    .prose-content ul li { list-style-type: disc; }
    .prose-content ol li { list-style-type: decimal; }
    .prose-content li {
      font-size: 17px;
      line-height: 1.7;
      color: #1C1B16;
      margin-bottom: 0.35em;
    }
    .prose-content strong { font-weight: 700; }
    .prose-content em { font-style: italic; }
    .prose-content a { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
    .prose-content a:hover { opacity: 0.8; }
    .prose-content hr { margin: 2rem 0; border: none; border-top: 1px solid #EDE5D0; }
    .prose-content blockquote {
      margin: 2.5em 0;
      padding: 0 0 0 24px;
      border-left: 4px solid var(--accent);
      font-style: italic;
      font-size: 20px;
      color: #141410;
      line-height: 1.55;
    }
    .prose-content table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.5rem;
      font-size: 15px;
      font-family: 'DM Sans', system-ui, sans-serif;
    }
    .prose-content th {
      background: #EDE5D0;
      padding: 0.5rem 0.875rem;
      text-align: left;
      font-weight: 700;
      border: 1px solid #D6CCBB;
    }
    .prose-content td {
      padding: 0.5rem 0.875rem;
      border: 1px solid #D6CCBB;
      background: #fff;
    }

    .article-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      margin-top: 2.5em;
      padding-top: 2em;
      border-top: 1px solid #EDE5D0;
    }
    .tag {
      font-size: 13px;
      color: #6B6455;
      background: #fff;
      border: 1px solid #EDE5D0;
      border-radius: 100px;
      padding: 5px 14px;
    }

    .article-cta {
      background: #141410;
      border-radius: 16px;
      padding: 40px;
      margin-top: 3em;
      text-align: center;
    }
    .article-cta h3 {
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 24px;
      font-weight: 700;
      color: #fff;
      margin-bottom: 12px;
    }
    .article-cta p {
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 16px;
      color: rgba(255,255,255,0.65);
      margin-bottom: 24px;
      max-width: 440px;
      margin-left: auto;
      margin-right: auto;
      line-height: 1.6;
    }
    .btn-gold {
      display: inline-block;
      background: var(--accent);
      color: #141410;
      font-family: 'DM Sans', system-ui, sans-serif;
      font-size: 15px;
      font-weight: 700;
      padding: 14px 28px;
      border-radius: 8px;
      text-decoration: none;
      transition: opacity 0.2s, transform 0.15s;
    }
    .btn-gold:hover { opacity: 0.85; transform: translateY(-1px); }

    .sidebar {
      position: sticky;
      top: 32px;
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .toc {
      background: #fff;
      border: 1px solid #EDE5D0;
      border-radius: 12px;
      padding: 22px;
    }
    .toc-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: #6B6455;
      margin-bottom: 14px;
    }
    .toc-list {
      list-style: none;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 2px;
    }
    .toc-list a {
      display: block;
      font-size: 14px;
      color: #6B6455;
      text-decoration: none;
      padding: 6px 10px;
      border-radius: 6px;
      line-height: 1.4;
      transition: background 0.15s, color 0.15s;
    }
    .toc-list a:hover,
    .toc-list a.active { background: #F6F0E4; color: #141410; }
    .toc-list a.active { font-weight: 600; }

    .sidebar-card {
      background: var(--accent);
      border-radius: 12px;
      padding: 22px;
    }
    .sidebar-card h4 { font-size: 16px; font-weight: 700; color: #141410; margin-bottom: 8px; }
    .sidebar-card p { font-size: 14px; color: rgba(20,20,16,0.72); margin-bottom: 16px; line-height: 1.5; }
    .btn-dark {
      display: block;
      background: #141410;
      color: #fff;
      font-size: 14px;
      font-weight: 600;
      padding: 10px 18px;
      border-radius: 7px;
      text-decoration: none;
      text-align: center;
      transition: opacity 0.2s;
    }
    .btn-dark:hover { opacity: 0.85; }

    .sidebar-share { display: flex; flex-direction: column; gap: 8px; }
    .sidebar-share-label {
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #6B6455;
    }
    .share-btns { display: flex; gap: 8px; }
    .share-btn {
      flex: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 500;
      color: #1C1B16;
      background: #fff;
      border: 1px solid #EDE5D0;
      border-radius: 7px;
      padding: 9px 12px;
      text-decoration: none;
      cursor: pointer;
      transition: background 0.15s;
      font-family: 'DM Sans', system-ui, sans-serif;
    }
    .share-btn:hover { background: #F6F0E4; }

    .back-link {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      font-size: 13px;
      font-weight: 600;
      color: var(--accent);
      text-decoration: none;
      padding: 10px 14px;
      background: rgba(0,0,0,0.05);
      border-radius: 8px;
      transition: opacity 0.2s;
    }
    .back-link:hover { opacity: 0.8; }

    @media (max-width: 860px) {
      .article-wrap { grid-template-columns: 1fr; gap: 40px; }
      .sidebar { position: static; }
      .article-meta-bar { gap: 14px; }
      .article-outer { padding: 32px 16px 64px; }
    }
  </style>

  <script>
    const progressBar = document.getElementById('progress-bar');
    const article = document.getElementById('article');
    if (progressBar && article) {
      window.addEventListener('scroll', () => {
        const total = article.offsetHeight - window.innerHeight;
        const scrolled = -article.getBoundingClientRect().top;
        const pct = Math.min(100, Math.max(0, (scrolled / total) * 100));
        progressBar.style.width = pct + '%';
      }, { passive: true });
    }

    const sections = document.querySelectorAll('.prose-content h2[id]');
    const tocLinks = document.querySelectorAll('[data-target]');
    if (sections.length && tocLinks.length) {
      const obs = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            tocLinks.forEach(l => l.classList.remove('active'));
            const active = document.querySelector(`[data-target="${entry.target.id}"]`);
            if (active) active.classList.add('active');
          }
        });
      }, { rootMargin: '-20% 0px -60% 0px' });
      sections.forEach(s => obs.observe(s));
    }

    const copyBtn = document.getElementById('copy-link-btn');
    if (copyBtn) {
      copyBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(window.location.href).then(() => {
          const orig = copyBtn.innerHTML;
          copyBtn.innerHTML = '<svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Copié !';
          setTimeout(() => { copyBtn.innerHTML = orig; }, 2000);
        });
      });
    }
  </script>
</SiteLayout>

<script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
