---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { tenant } from "../../../config/tenant";
import { getCollection, render } from "astro:content";

export const prerender = true;
export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { lang: post.data.lang ?? "fr", slug: post.data.url_slug },
    props: { post },
  }));
}

const { lang } = Astro.params as { lang: string };
const { post } = Astro.props;
const { Content } = await render(post);

const currentPath = `/${lang}/blog/${post.data.url_slug}`;

const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.meta_description,
  url: `${tenant.siteUrl}${currentPath}`,
  inLanguage: lang === "fr" ? "fr-CA" : "en-CA",
  datePublished: post.data.date ?? "2026-04-27",
  dateModified: post.data.date ?? "2026-04-27",
  publisher: {
    "@type": "Organization",
    name: tenant.name,
    url: tenant.siteUrl,
    logo: { "@type": "ImageObject", url: `${tenant.siteUrl}${tenant.logoSrc}` },
  },
  author: { "@type": "Organization", name: tenant.name, url: tenant.siteUrl },
};
---

<SiteLayout
  title={post.data.title}
  description={post.data.meta_description}
  lang={lang}
  currentPath={currentPath}
>
  <style>
    .prose-article {
      color: rgba(17,17,17,0.88);
      font-size: 1.0625rem;
      line-height: 1.75;
    }
    .prose-article h2 {
      font-size: 1.375rem;
      font-weight: 700;
      margin-top: 2.5rem;
      margin-bottom: 0.875rem;
      color: rgba(17,17,17,0.92);
      line-height: 1.3;
    }
    .prose-article h3 {
      font-size: 1.125rem;
      font-weight: 700;
      margin-top: 1.75rem;
      margin-bottom: 0.625rem;
      color: rgba(17,17,17,0.88);
    }
    .prose-article p {
      margin-bottom: 1.25rem;
    }
    .prose-article ul, .prose-article ol {
      margin-bottom: 1.25rem;
      padding-left: 1.5rem;
    }
    .prose-article li {
      margin-bottom: 0.4rem;
    }
    .prose-article ul li { list-style-type: disc; }
    .prose-article ol li { list-style-type: decimal; }
    .prose-article strong { font-weight: 700; }
    .prose-article em { font-style: italic; }
    .prose-article a {
      color: var(--accent);
      text-decoration: underline;
      text-underline-offset: 3px;
    }
    .prose-article a:hover { opacity: 0.8; }
    .prose-article hr {
      margin: 2rem 0;
      border: none;
      border-top: 1px solid rgba(0,0,0,0.10);
    }
    .prose-article table {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 1.5rem;
      font-size: 0.9375rem;
    }
    .prose-article th {
      background: rgba(0,0,0,0.04);
      padding: 0.5rem 0.875rem;
      text-align: left;
      font-weight: 700;
      border: 1px solid rgba(0,0,0,0.10);
    }
    .prose-article td {
      padding: 0.5rem 0.875rem;
      border: 1px solid rgba(0,0,0,0.10);
    }
    .prose-article blockquote {
      border-left: 3px solid var(--accent);
      padding-left: 1rem;
      margin: 1.5rem 0;
      color: rgba(17,17,17,0.65);
      font-style: italic;
    }
    .angle-badge {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      padding: 0.2rem 0.7rem;
      border-radius: 999px;
      color: #fff;
      background: var(--accent);
    }
    .animate-fade-up { animation: fadeUp 0.5s ease both; }
    .animate-fade-up-delay-1 { animation-delay: 0.1s; }
    @keyframes fadeUp { from { opacity:0; transform:translateY(14px); } to { opacity:1; transform:none; } }
  </style>

  <!-- HEADER -->
  <div slot="header" class="flex flex-col items-center">
    <img src={tenant.logoSrc} alt={tenant.name} class="h-28 md:h-36 w-auto drop-shadow-lg" fetchpriority="high" loading="eager" />
    <p class="mt-3 text-xs tracking-[0.35em] uppercase animate-fade-up animate-fade-up-delay-1"
       style="color: color-mix(in srgb, var(--text) 55%, transparent);">
      <a href={`/${lang}/blog`} style="color: inherit; text-decoration: none;">
        {lang === "fr" ? "← Blogue TI" : "← IT Blog"}
      </a>
    </p>
  </div>

  <!-- HERO -->
  <div slot="hero" class="relative max-w-3xl mx-auto px-4 text-center z-20 pt-2 pb-10">
    <div class="pointer-events-none absolute left-1/2 top-8 -translate-x-1/2 w-[60%] h-20 blur-[70px] opacity-50"
         style="background: color-mix(in srgb, var(--accent) 20%, transparent);"></div>
    <div class="mt-4 animate-fade-up">
      <span class="angle-badge">{post.data.angle}</span>
    </div>
    <h1 class="mt-4 text-3xl md:text-4xl font-bold tracking-tight animate-fade-up leading-tight" style="color: var(--text);">
      {post.data.title}
    </h1>
    <p class="mt-4 text-base animate-fade-up animate-fade-up-delay-1 max-w-2xl mx-auto"
       style="color: color-mix(in srgb, var(--text) 72%, transparent);">{post.data.meta_description}</p>
  </div>

  <!-- BAND -->
  <section class="relative w-full overflow-hidden" style="background: var(--band);">
    <div class="h-[2px] w-full" style="background: var(--accent);"></div>
    <div class="h-12 w-full"
         style="background: linear-gradient(to bottom, color-mix(in srgb, var(--accent) 16%, transparent), transparent);"></div>

    <div class="relative z-10">
      <main class="mx-auto max-w-4xl px-4 pb-20 pt-6">
        <div class="rounded-3xl bg-white p-8 md:p-12 shadow-xl border border-black/10">
          <div class="prose-article">
            <Content />
          </div>
        </div>

        <!-- Back link -->
        <div class="mt-8 text-center">
          <a href={`/${lang}/blog`}
             class="inline-flex items-center gap-2 text-sm font-semibold px-5 py-2.5 rounded-xl"
             style="background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent);">
            {lang === "fr" ? "← Retour au blogue" : "← Back to blog"}
          </a>
        </div>
      </main>
    </div>
  </section>
</SiteLayout>

<script type="application/ld+json" is:inline set:html={JSON.stringify(articleSchema)} />
