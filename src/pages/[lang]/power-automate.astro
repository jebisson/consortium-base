---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { t } from "../../i18n/utils";
import { tenant } from "../../config/tenant";

export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "fr" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: string };
const tr = t(lang);
const a = tr.automate;
const currentPath = `/${lang}/power-automate`;
---

<SiteLayout title={a.title} description={a.heroDesc} lang={lang} currentPath={currentPath}>
  <style>
    .card-dark {
      background: var(--card);
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow: 0 20px 40px rgba(0,0,0,0.45), 0 4px 12px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.07);
      border-radius: 1rem;
    }
    .hover-tint {
      background: radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 62%);
      position: absolute; inset: 0; pointer-events: none; opacity: 0.70; transition: opacity 0.3s;
    }
    .band-title { color: rgba(17,17,17,0.92); }
    .band-soft  { color: rgba(17,17,17,0.75); }
    .band-muted { color: rgba(17,17,17,0.62); }
    .icon-accent { color: var(--accent); }
    .card-icon { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); }
    .focus-ring:focus { outline: none; box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 30%, transparent); }
    .pill { background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); color: color-mix(in srgb, var(--text) 92%, transparent); }
  </style>

  <!-- HEADER -->
  <div slot="header" class="flex flex-col items-center">
    <img src={tenant.logoSrc} alt={tenant.name} class="h-28 md:h-36 w-auto drop-shadow-lg" />
    <p class="mt-3 text-xs tracking-[0.35em] uppercase"
       style="color: color-mix(in srgb, var(--text) 55%, transparent);">{a.headerSubtitle}</p>
  </div>

  <!-- HERO -->
  <div slot="hero" class="relative max-w-4xl mx-auto px-4 text-center z-20 pt-2 pb-10">
    <div class="pointer-events-none absolute left-1/2 top-8 -translate-x-1/2 w-[65%] h-24 blur-[80px] opacity-60"
         style="background: color-mix(in srgb, var(--accent) 20%, transparent);"></div>
    <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight animate-fade-up" style="color: var(--text);">
      {a.heroTitle}
    </h1>
    <p class="mt-4 text-lg soft animate-fade-up animate-fade-up-delay-1 max-w-2xl mx-auto">{a.heroDesc}</p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center animate-fade-up animate-fade-up-delay-2">
      <a href="#exemples"
         class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold transition hover:brightness-110 active:scale-95"
         style="background: var(--accent); color: #111; box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 30%, transparent);">
        {lang === "fr" ? "Voir les exemples" : "See examples"}
      </a>
    </div>
    <div class="mt-8 flex flex-wrap gap-2 justify-center animate-fade-up animate-fade-up-delay-3">
      {a.heroTags.map((tag) => <span class="pill px-4 py-2 rounded-full text-sm">{tag}</span>)}
    </div>
  </div>

  <!-- BAND -->
  <section class="relative w-full overflow-hidden" style="background: var(--band);">
    <div class="h-[2px] w-full" style="background: var(--accent);"></div>
    <div class="h-12 w-full"
         style="background: linear-gradient(to bottom, color-mix(in srgb, var(--accent) 16%, transparent), transparent);"></div>

    <div class="relative z-10">
      <main class="mx-auto max-w-6xl px-4 pb-20 pt-10 space-y-14">

        <!-- BENEFITS -->
        <section>
          <div class="rounded-3xl bg-white p-8 md:p-10 shadow-xl border border-black/10 reveal">
            <h2 class="text-3xl font-semibold band-title">{a.benefitsTitle}</h2>
            <p class="mt-3 text-lg band-soft max-w-3xl">{a.benefitsDesc}</p>
            <div class="mt-8 grid gap-4 md:grid-cols-3">
              {a.benefits.map((b, i) => (
                <div class="rounded-2xl p-6 border border-black/10 reveal">
                  <div class="flex items-start gap-3">
                    <div class="h-11 w-11 rounded-xl card-icon flex items-center justify-center shrink-0">
                      {i === 0 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z"/></svg>}
                      {i === 1 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-6.042a48.42 48.42 0 00-6 2.558A2.25 2.25 0 005.25 8.91v4.819a6.75 6.75 0 003.022 5.625l3.095 2.06a.75.75 0 00.816 0l3.095-2.06a6.75 6.75 0 003.022-5.625V8.91a2.25 2.25 0 00-1.25-2.132 48.42 48.42 0 00-6-2.558z"/></svg>}
                      {i === 2 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 005.454-1.31A8.967 8.967 0 0118 9.75v-.7V9A6 6 0 006 9v.75a8.967 8.967 0 01-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 01-5.714 0m5.714 0a3 3 0 11-5.714 0"/></svg>}
                      {i === 3 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244"/></svg>}
                      {i === 4 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M7.5 21L3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"/></svg>}
                      {i === 5 && <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17.25 6.75L22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3l-4.5 16.5"/></svg>}
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold band-title">{b.title}</h3>
                      <p class="mt-1 band-muted">{b.desc}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- USE CASES -->
        <section id="exemples">
          <h2 class="text-3xl font-semibold reveal" style="color: black;">{a.usecasesTitle}</h2>
          <p class="mt-2 max-w-3xl reveal" style="color: rgba(17,17,17,0.70);">{a.usecasesDesc}</p>
          <div class="mt-7 grid gap-6 md:grid-cols-2">
            {a.usecases.map((uc, i) => (
              <div class="relative rounded-2xl p-7 card-dark overflow-hidden reveal">
                <div class="hover-tint"></div>
                <div class="relative flex items-start gap-4">
                  <div class="h-11 w-11 rounded-xl flex items-center justify-center font-bold shrink-0"
                       style="background: color-mix(in srgb, var(--accent) 22%, transparent); color: var(--text); border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);">
                    {i + 1}
                  </div>
                  <div>
                    <h3 class="text-lg font-semibold soft">{uc.title}</h3>
                    <p class="mt-2 muted text-sm leading-relaxed">{uc.desc}</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- CTA + FORM -->
        <section id="demande" class="pb-6">
          <div class="rounded-3xl p-8 md:p-10 card-dark overflow-hidden relative reveal">
            <div class="hover-tint" style="opacity: 0.60;"></div>
            <div class="pointer-events-none absolute -top-20 -left-20 h-52 w-52 rounded-full blur-3xl opacity-25" style="background: var(--accent);"></div>
            <div class="pointer-events-none absolute -bottom-20 -right-20 h-52 w-52 rounded-full blur-3xl opacity-15" style="background: var(--accent);"></div>

            <div class="relative flex flex-col gap-8">
              <div>
                <h2 class="text-3xl font-semibold soft">{a.ctaTitle}</h2>
                <p class="mt-2 muted">{a.ctaDesc}</p>
                <div class="mt-6">
                  <button id="openFormBtn" type="button"
                          class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold transition hover:brightness-110 focus-ring"
                          style="background: var(--accent); color: #111; box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 30%, transparent);">
                    {a.ctaOpenBtn}
                  </button>
                </div>
                <p id="automateStatus" class="mt-4 text-sm muted"></p>
              </div>

              <div>
                <div id="formContainer" class="overflow-hidden max-h-0 opacity-0 transition-all duration-500">
                  <div class="rounded-2xl p-6 md:p-7"
                       style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.10);">
                    <div class="flex items-center justify-between gap-4 mb-4">
                      <h3 class="text-xl font-semibold soft">{a.formTitle}</h3>
                      <button id="closeFormBtn" type="button"
                              class="px-3 py-2 rounded-lg card-icon muted hover:brightness-110 focus-ring text-sm">
                        {a.formCloseBtn}
                      </button>
                    </div>
                    <form id="automateForm" class="space-y-4" style="background: rgba(255,255,255,0.05); border-radius: 0.75rem; padding: 1.5rem; border: 1px solid rgba(255,255,255,0.08);">
                      <input type="hidden" name="service_type" value="TI" />
                      <input type="hidden" name="service_name" value="Power Automate" />
                      {tenant.id !== 'eesad' && <>
                      <!-- Questions préliminaires -->
                      <div>
                        <p class="text-sm font-semibold mb-2 soft">{tr.common.memberQuestion} <span class="text-rose-400">*</span></p>
                        <div class="flex flex-wrap gap-6 text-sm soft">
                          <label class="flex items-center gap-2"><input type="radio" name="is_member" value="oui" required style="accent-color: var(--accent);" /> {tr.common.yes}</label>
                          <label class="flex items-center gap-2"><input type="radio" name="is_member" value="non" style="accent-color: var(--accent);" /> {tr.common.no}</label>
                          <label class="flex items-center gap-2"><input type="radio" name="is_member" value="ne_sais_pas" style="accent-color: var(--accent);" /> {tr.common.dontKnow}</label>
                        </div>
                      </div>
                      <div>
                        <p class="text-sm font-semibold mb-2 soft">{tr.common.federationQuestion} <span class="text-rose-400">*</span></p>
                        <div class="flex flex-wrap gap-6 text-sm soft">
                          <label class="flex items-center gap-2"><input type="radio" name="is_federation" value="oui" required style="accent-color: var(--accent);" /> {tr.common.yes}</label>
                          <label class="flex items-center gap-2"><input type="radio" name="is_federation" value="non" style="accent-color: var(--accent);" /> {tr.common.no}</label>
                          <label class="flex items-center gap-2"><input type="radio" name="is_federation" value="ne_sais_pas" style="accent-color: var(--accent);" /> {tr.common.dontKnow}</label>
                        </div>
                      </div>
                      <div>
                        <p class="text-sm font-semibold mb-2 soft">{tr.common.companyTypeQuestion} <span class="text-rose-400">*</span></p>
                        <div class="flex flex-wrap gap-6 text-sm soft">
                          <label class="flex items-center gap-2"><input type="radio" name="company_type" value="cooperative" required style="accent-color: var(--accent);" /> {tr.common.cooperative}</label>
                          <label class="flex items-center gap-2"><input type="radio" name="company_type" value="mutuelle" style="accent-color: var(--accent);" /> {tr.common.mutuelle}</label>
                          <label class="flex items-center gap-2"><input type="radio" name="company_type" value="obnl" style="accent-color: var(--accent);" /> {tr.common.obnl}</label>
                          <label class="flex items-center gap-2"><input type="radio" name="company_type" value="autre" style="accent-color: var(--accent);" /> {tr.common.other}</label>
                        </div>
                      </div>
                      </>}
                      <!-- Nom de l'entreprise -->
                      <div>
                        <label class="block text-sm font-semibold mb-1 soft">{tr.common.companyName} <span class="text-rose-400">*</span></label>
                        <input type="text" name="company_name" required
                               class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                               style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
                      </div>
                      <!-- Adresse -->
                      <div>
                        <label class="block text-sm font-semibold mb-1 soft">{tr.common.address} <span class="text-rose-400">*</span></label>
                        <input type="text" name="street_address" required
                               class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm mb-1"
                               style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
                        <p class="text-xs mb-2 muted">{tr.common.streetAddress}</p>
                        <div class="grid grid-cols-2 gap-3 mb-1">
                          <div>
                            <input type="text" name="city" required
                                   class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                                   style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
                            <p class="text-xs mt-1 muted">{tr.common.city}</p>
                          </div>
                          <div>
                            <select name="province" required
                                    class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                                    style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);">
                              <option>Québec</option><option>Ontario</option><option>Colombie-Britannique</option>
                              <option>Alberta</option><option>Manitoba</option><option>Saskatchewan</option>
                              <option>Nouvelle-Écosse</option><option>Nouveau-Brunswick</option>
                              <option>Terre-Neuve-et-Labrador</option><option>Île-du-Prince-Édouard</option>
                            </select>
                            <p class="text-xs mt-1 muted">{tr.common.province}</p>
                          </div>
                        </div>
                        <input type="text" name="postal_code" required
                               class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm mt-1"
                               style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text); max-width: 50%; display: block;" />
                        <p class="text-xs mt-1 muted">{tr.common.postalCode}</p>
                      </div>
                      <!-- Personne contact + Titre -->
                      <div class="grid md:grid-cols-2 gap-4">
                        <div>
                          <label class="block text-sm font-semibold mb-1 soft">{tr.common.contactPerson} <span class="text-rose-400">*</span></label>
                          <input type="text" name="contact_person" required
                                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
                        </div>
                        <div>
                          <label class="block text-sm font-semibold mb-1 soft">{tr.common.contactTitle} <span class="text-rose-400">*</span></label>
                          <input type="text" name="contact_title" required
                                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
                        </div>
                      </div>
                      <!-- Courriel + Téléphone -->
                      <div class="grid md:grid-cols-2 gap-4">
                        <div>
                          <label class="block text-sm font-semibold mb-1 soft">{tr.common.email} <span class="text-rose-400">*</span></label>
                          <input type="email" name="automate_email" required
                                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
                        </div>
                        <div>
                          <label class="block text-sm font-semibold mb-1 soft">{tr.common.phone} <span class="text-rose-400">*</span></label>
                          <input type="tel" name="automate_tel" required
                                 class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                                 style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);" />
                        </div>
                      </div>
                      <!-- Message -->
                      <div>
                        <label class="block text-sm font-semibold mb-1 soft">{a.formMsgLabel} <span class="text-rose-400">*</span></label>
                        <textarea name="automate_msg" rows="4" required
                                  class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm resize-none"
                                  style="background: rgba(0,0,0,0.28); border: 1px solid rgba(255,255,255,0.12); color: var(--text);"></textarea>
                      </div>
                      <label class="flex items-start gap-2.5 cursor-pointer">
                        <input type="checkbox" required name="consent"
                               class="mt-0.5 h-4 w-4 shrink-0 rounded focus-ring"
                               style="accent-color: var(--accent);" />
                        <span class="text-xs muted">{tenant.consent[lang as 'fr' | 'en']}</span>
                      </label>
                      <button type="submit"
                              class="w-full inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold transition hover:brightness-110 focus-ring"
                              style="background: var(--accent); color: #111;">
                        {a.formSubmitBtn}
                      </button>
                    </form>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

      </main>
    </div>
  </section>
</SiteLayout>

<script define:vars={{ msgSending: tr.common.sending, msgDone: tr.common.sent, msgError: tr.common.errorSend, msgNetwork: tr.common.errorNetwork }}>
  const btn    = document.getElementById("openFormBtn");
  const close  = document.getElementById("closeFormBtn");
  const panel  = document.getElementById("formContainer");
  const form   = document.getElementById("automateForm");
  const status = document.getElementById("automateStatus");
  if (btn && close && panel && form && status) {
    btn.addEventListener("click", () => {
      panel.style.maxHeight = panel.scrollHeight + "px";
      panel.style.opacity = "1";
      panel.scrollIntoView({ behavior: "smooth", block: "nearest" });
    });
    close.addEventListener("click", () => { panel.style.maxHeight = "0"; panel.style.opacity = "0"; });
    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const data = {};
      for (const [k, v] of new FormData(form).entries()) data[k] = v;
      status.textContent = msgSending;
      try {
        const res = await fetch("/api/submit", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
        status.textContent = res.ok ? msgDone : msgError;
        if (res.ok) form.reset();
      } catch { status.textContent = msgNetwork; }
    });
  }
</script>
