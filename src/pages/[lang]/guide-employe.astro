---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { t } from "../../i18n/utils";
import { tenant } from "../../config/tenant";

export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "fr" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: string };
const tr = t(lang);
const g = tr.guide;
const currentPath = `/${lang}/guide-employe`;
---

<SiteLayout title={g.title} description={g.heroDesc} lang={lang} currentPath={currentPath}>
  <style>
    .card-dark {
      background: var(--card);
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow: 0 20px 40px rgba(0,0,0,0.45), 0 4px 12px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.07);
      border-radius: 1rem;
    }
    .hover-tint {
      background: radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 62%);
      position: absolute; inset: 0; pointer-events: none; opacity: 0.70;
      transition: opacity 0.3s;
    }
    .band-title { color: rgba(17,17,17,0.92); }
    .band-soft  { color: rgba(17,17,17,0.75); }
    .band-muted { color: rgba(17,17,17,0.62); }
    .icon-accent { color: var(--accent); }
    .card-icon {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
    }
    .pill {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
      color: color-mix(in srgb, var(--text) 92%, transparent);
    }
    .never-item {
      display: flex; align-items: flex-start; gap: 0.75rem;
    }
    .never-dot {
      margin-top: 0.25rem; flex-shrink: 0;
      height: 1.25rem; width: 1.25rem; border-radius: 9999px;
      display: flex; align-items: center; justify-content: center;
      background: color-mix(in srgb, #ef4444 18%, transparent);
      border: 1px solid color-mix(in srgb, #ef4444 35%, transparent);
    }
  </style>

  <!-- HEADER -->
  <div slot="header" class="flex flex-col items-center">
    <img src={tenant.logoSrc} alt={tenant.name} class="h-28 md:h-36 w-auto drop-shadow-lg" fetchpriority="high" loading="eager" />
    <p class="mt-3 text-xs tracking-[0.35em] uppercase"
       style="color: color-mix(in srgb, var(--text) 55%, transparent);">{g.headerSubtitle}</p>
  </div>

  <!-- HERO -->
  <div slot="hero" class="relative max-w-3xl mx-auto px-4 text-center z-20 pt-2 pb-10">
    <div class="pointer-events-none absolute left-1/2 top-8 -translate-x-1/2 w-[65%] h-24 blur-[80px] opacity-60"
         style="background: color-mix(in srgb, var(--accent) 20%, transparent);"></div>
    <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight animate-fade-up" style="color: var(--text);">
      {g.heroTitle}
    </h1>
    <p class="mt-5 text-lg leading-relaxed animate-fade-up animate-fade-up-delay-1"
       style="color: color-mix(in srgb, var(--text) 72%, transparent);">{g.heroDesc}</p>
    <div class="mt-3 flex items-center justify-center gap-2 animate-fade-up animate-fade-up-delay-2">
      <div class="h-px w-8" style="background: color-mix(in srgb, var(--accent) 50%, transparent);"></div>
      <p class="text-sm" style="color: color-mix(in srgb, var(--text) 48%, transparent);">{g.heroSub}</p>
      <div class="h-px w-8" style="background: color-mix(in srgb, var(--accent) 50%, transparent);"></div>
    </div>
    <div class="mt-6 flex flex-wrap gap-2 justify-center animate-fade-up animate-fade-up-delay-2">
      {g.pills.map((tag) => (
        <span class="pill px-4 py-2 rounded-full text-sm">{tag}</span>
      ))}
    </div>
  </div>

  <!-- BAND -->
  <section class="relative w-full overflow-hidden" style="background: var(--band);">
    <div class="h-[2px] w-full" style="background: var(--accent);"></div>
    <div class="h-12 w-full"
         style="background: linear-gradient(to bottom, color-mix(in srgb, var(--accent) 16%, transparent), transparent);"></div>

    <div class="relative z-10">
      <main class="mx-auto max-w-6xl px-4 pb-20 pt-10 space-y-14">

        <!-- WHY -->
        <section>
          <div class="rounded-3xl bg-white p-8 md:p-10 shadow-xl border border-black/10 reveal">
            <h2 class="text-3xl font-semibold band-title">{g.introTitle}</h2>
            <div class="mt-8 grid gap-4 md:grid-cols-3">
              {g.introCards.map((card, i) => (
                <div class="rounded-2xl p-6 border border-black/10 reveal">
                  <div class="flex items-start gap-3">
                    <div class="h-11 w-11 rounded-xl card-icon flex items-center justify-center shrink-0">
                      {i === 0 && (
                        <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
                        </svg>
                      )}
                      {i === 1 && (
                        <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
                        </svg>
                      )}
                      {i === 2 && (
                        <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                          <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>
                        </svg>
                      )}
                    </div>
                    <div>
                      <h3 class="text-lg font-semibold band-title">{card.title}</h3>
                      <p class="mt-1 band-muted">{card.desc}</p>
                    </div>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- 5 SECTIONS -->
        <section>
          <h2 class="text-3xl font-semibold reveal mb-7" style="color: black;">{g.sectionsTitle}</h2>
          <div class="grid gap-4 md:grid-cols-2">
            {g.sections.map((sec) => (
              <div class="relative rounded-2xl p-6 card-dark overflow-hidden reveal">
                <div class="hover-tint"></div>
                <div class="relative">
                  <div class="flex items-start gap-3 mb-4">
                    <div class="h-10 w-10 rounded-xl flex items-center justify-center font-bold text-sm shrink-0"
                         style="background: color-mix(in srgb, var(--accent) 22%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 28%, transparent);">
                      {sec.num}
                    </div>
                    <h3 class="text-lg font-semibold mt-1.5" style="color: color-mix(in srgb, var(--text) 95%, transparent);">{sec.title}</h3>
                  </div>
                  <p class="text-sm mb-3" style="color: color-mix(in srgb, var(--text) 70%, transparent);">{sec.intro}</p>
                  <ul class="space-y-1.5 mb-4">
                    {sec.items.map((item) => (
                      <li class="flex items-start gap-2 text-sm" style="color: color-mix(in srgb, var(--text) 78%, transparent);">
                        <svg class="h-4 w-4 mt-0.5 shrink-0 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                          <path d="M20 6L9 17l-5-5"/>
                        </svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                  <div class="rounded-lg px-3 py-2 text-xs"
                       style="background: color-mix(in srgb, var(--accent) 10%, transparent); border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent); color: color-mix(in srgb, var(--text) 85%, transparent);">
                    {sec.note}
                  </div>
                </div>
              </div>
            ))}
          </div>
        </section>

        <!-- NEVER -->
        <section>
          <div class="rounded-3xl p-8 md:p-10 card-dark overflow-hidden relative reveal">
            <div class="hover-tint" style="background: radial-gradient(circle at 18% 18%, color-mix(in srgb, #ef4444 12%, transparent), transparent 62%);"></div>
            <div class="relative">
              <div class="flex items-center gap-3 mb-6">
                <div class="h-11 w-11 rounded-xl flex items-center justify-center shrink-0"
                     style="background: color-mix(in srgb, #ef4444 14%, transparent); border: 1px solid color-mix(in srgb, #ef4444 28%, transparent);">
                  <svg class="h-6 w-6" style="color: #f87171;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
                  </svg>
                </div>
                <h2 class="text-2xl font-semibold" style="color: color-mix(in srgb, var(--text) 95%, transparent);">{g.neverTitle}</h2>
              </div>
              <ul class="grid gap-3 md:grid-cols-2">
                {g.neverItems.map((item) => (
                  <li class="never-item">
                    <span class="never-dot">
                      <svg class="h-3 w-3" style="color: #f87171;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
                        <path d="M18 6L6 18M6 6l12 12"/>
                      </svg>
                    </span>
                    <span class="text-sm" style="color: color-mix(in srgb, var(--text) 78%, transparent);">{item}</span>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>

        <!-- CLICKED BY MISTAKE -->
        <section>
          <div class="rounded-3xl bg-white p-8 md:p-10 shadow-xl border border-black/10 reveal">
            <h2 class="text-3xl font-semibold band-title">{g.clickedTitle}</h2>
            <p class="mt-2 band-soft max-w-3xl">{g.clickedDesc}</p>
            <div class="mt-7 grid gap-4 md:grid-cols-4">
              {g.clickedSteps.map((step) => (
                <div class="rounded-2xl p-5 border border-black/10 reveal">
                  <div class="h-10 w-10 rounded-xl flex items-center justify-center font-bold mb-3"
                       style="background: color-mix(in srgb, var(--accent) 14%, transparent); color: var(--accent); border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);">
                    {step.n}
                  </div>
                  <h3 class="text-base font-semibold band-title">{step.t}</h3>
                  <p class="mt-1 text-sm band-muted">{step.d}</p>
                </div>
              ))}
            </div>
          </div>
        </section>

        <!-- WHEN TO REPORT -->
        <section>
          <div class="rounded-3xl p-8 md:p-10 card-dark overflow-hidden relative reveal">
            <div class="hover-tint"></div>
            <div class="relative flex flex-col md:flex-row gap-8">
              <div class="md:w-1/3">
                <div class="h-11 w-11 rounded-xl card-icon flex items-center justify-center mb-4">
                  <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.38 2 2 0 0 1 3.6 1.18h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.77a16 16 0 0 0 6.29 6.29l.95-.95a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
                  </svg>
                </div>
                <h2 class="text-2xl font-semibold" style="color: color-mix(in srgb, var(--text) 95%, transparent);">{g.reportTitle}</h2>
                <p class="mt-2 text-sm" style="color: color-mix(in srgb, var(--text) 65%, transparent);">{g.reportDesc}</p>
                <p class="mt-4 text-sm font-semibold" style="color: var(--accent);">{g.reportNote}</p>
              </div>
              <ul class="md:w-2/3 grid gap-2 sm:grid-cols-2 content-start">
                {g.reportItems.map((item) => (
                  <li class="flex items-start gap-2 text-sm" style="color: color-mix(in srgb, var(--text) 78%, transparent);">
                    <svg class="h-4 w-4 mt-0.5 shrink-0 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M20 6L9 17l-5-5"/>
                    </svg>
                    {item}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </section>

        <!-- SUMMARY -->
        <section class="pb-6">
          <div class="rounded-3xl bg-white p-8 md:p-10 shadow-xl border border-black/10 reveal">
            <h2 class="text-3xl font-semibold band-title">{g.summaryTitle}</h2>
            <ul class="mt-6 flex flex-col sm:flex-row flex-wrap gap-3">
              {g.summaryItems.map((item) => (
                <li class="flex items-center gap-2 rounded-xl px-4 py-2.5 text-sm font-medium"
                    style="background: color-mix(in srgb, var(--accent) 10%, transparent); color: rgba(17,17,17,0.85); border: 1px solid color-mix(in srgb, var(--accent) 20%, transparent);">
                  <svg class="h-4 w-4 shrink-0 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <path d="M20 6L9 17l-5-5"/>
                  </svg>
                  {item}
                </li>
              ))}
            </ul>
            <p class="mt-6 band-soft max-w-3xl">{g.summaryNote}</p>
          </div>
        </section>

      </main>
    </div>
  </section>

</SiteLayout>
