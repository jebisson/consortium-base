---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { t } from "../../i18n/utils";
import { tenant } from "../../config/tenant";

export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "fr" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: string };
const tr = t(lang);
const currentPath = `/${lang}/contact`;

const isFr = lang === "fr";
---

<SiteLayout
  title={isFr ? `Contact – ${tenant.name}` : `Contact – ${tenant.name}`}
  description={isFr ? "Contactez-nous pour toute question sur nos services TI." : "Contact us for any question about our IT services."}
  lang={lang}
  currentPath={currentPath}
>
  <style>
    .card-dark {
      background: var(--card);
      border: 1px solid rgba(255,255,255,0.07);
      box-shadow: 0 20px 40px rgba(0,0,0,0.45), 0 4px 12px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.07);
      border-radius: 1rem;
    }
    .focus-ring:focus {
      outline: none;
      box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 30%, transparent);
    }
  </style>

  <!-- HEADER -->
  <div slot="header" class="flex flex-col items-center">
    <img src={tenant.logoSrc} alt={tenant.name} class="h-28 md:h-36 w-auto drop-shadow-lg" />
    <p class="mt-3 text-xs tracking-[0.35em] uppercase"
       style="color: color-mix(in srgb, var(--text) 55%, transparent);">
      {isFr ? "Nous joindre" : "Get in touch"}
    </p>
  </div>

  <!-- HERO -->
  <div slot="hero" class="relative max-w-4xl mx-auto px-4 text-center z-20 pt-2 pb-10">
    <div class="pointer-events-none absolute left-1/2 top-8 -translate-x-1/2 w-[65%] h-24 blur-[80px] opacity-60"
         style="background: color-mix(in srgb, var(--accent) 20%, transparent);"></div>
    <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight animate-fade-up" style="color: var(--text);">
      {isFr ? "Une question ? Écrivez-nous." : "A question? Write to us."}
    </h1>
    <p class="mt-4 text-lg animate-fade-up animate-fade-up-delay-1"
       style="color: color-mix(in srgb, var(--text) 72%, transparent);">
      {isFr
        ? "Notre équipe vous répond dans les meilleurs délais."
        : "Our team will get back to you as soon as possible."}
    </p>
  </div>

  <!-- MAIN -->
  <main>
    <section class="relative w-full" style="background: var(--band);">
      <div class="h-[2px] w-full" style="background: var(--accent);"></div>
      <div class="h-10 w-full"
           style="background: linear-gradient(to bottom, color-mix(in srgb, var(--accent) 14%, transparent), transparent);"></div>

      <div class="relative z-10 mx-auto max-w-2xl px-4 pb-20 pt-4">
        <form id="contactForm" class="card-dark p-8 space-y-5 reveal">
          <input type="hidden" name="form_type" value="contact" />

          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-medium mb-1.5"
                     style="color: color-mix(in srgb, var(--text) 80%, transparent);">
                {isFr ? "Nom" : "Name"} <span class="text-rose-400">*</span>
              </label>
              <input name="contact_nom" required
                     class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                     style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);" />
            </div>
            <div>
              <label class="block text-sm font-medium mb-1.5"
                     style="color: color-mix(in srgb, var(--text) 80%, transparent);">
                {tr.common.email} <span class="text-rose-400">*</span>
              </label>
              <input type="email" name="contact_email" required
                     class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                     style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);" />
            </div>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5"
                   style="color: color-mix(in srgb, var(--text) 80%, transparent);">
              {tr.common.orgName} {tr.common.optional}
            </label>
            <input name="contact_org"
                   class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                   style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);" />
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5"
                   style="color: color-mix(in srgb, var(--text) 80%, transparent);">
              {tr.common.subject} <span class="text-rose-400">*</span>
            </label>
            <select name="contact_subject" required
                    class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                    style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);">
              <option value="" disabled selected style="background-color: var(--bg); color: var(--text);">
                {isFr ? "Choisir un sujet…" : "Choose a subject…"}
              </option>
              {(isFr ? [
                "Informations générales",
                "Sauvegarde Microsoft 365",
                "Sécurité 365",
                "Gestion TI / RMM / EDR",
                "Formation & intégration",
                "Service conseil",
                "Adhésion",
                "Autre",
              ] : [
                "General information",
                "Microsoft 365 Backup",
                "Security 365",
                "IT Management / RMM / EDR",
                "Training & onboarding",
                "IT Advisory",
                "Membership",
                "Other",
              ]).map((opt) => (
                <option value={opt} style="background-color: var(--bg); color: var(--text);">{opt}</option>
              ))}
            </select>
          </div>

          <div>
            <label class="block text-sm font-medium mb-1.5"
                   style="color: color-mix(in srgb, var(--text) 80%, transparent);">
              {tr.common.message} <span class="text-rose-400">*</span>
            </label>
            <textarea name="contact_message" required rows="5"
                      class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm resize-none"
                      style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);"></textarea>
          </div>

          <button type="submit"
                  class="w-full inline-flex items-center justify-center px-8 py-4 rounded-xl font-semibold text-base transition hover:brightness-110"
                  style="background: var(--accent); color: #111; box-shadow: 0 10px 28px color-mix(in srgb, var(--accent) 30%, transparent);">
            {isFr ? "Envoyer le message" : "Send message"}
          </button>

          <label class="flex items-start gap-2.5 cursor-pointer">
            <input type="checkbox" required name="consent"
                   class="mt-0.5 h-4 w-4 shrink-0 rounded focus-ring"
                   style="accent-color: var(--accent);" />
            <span class="text-xs" style="color: color-mix(in srgb, var(--text) 65%, transparent);">
              {tenant.consent[lang as 'fr' | 'en']}
            </span>
          </label>

          <p id="contactStatus" class="text-sm text-center"
             style="color: color-mix(in srgb, var(--text) 60%, transparent);"></p>
        </form>
      </div>
    </section>
  </main>
</SiteLayout>

<script define:vars={{ msgSending: tr.common.sending, msgDone: tr.common.sent, msgError: tr.common.errorSend, msgNetwork: tr.common.errorNetwork }}>
  const form   = document.getElementById("contactForm");
  const status = document.getElementById("contactStatus");

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    if (status) status.textContent = msgSending;

    const fd   = new FormData(form);
    const data = {};
    for (const [k, v] of fd.entries()) data[k] = v;

    try {
      const res = await fetch("/api/submit", {
        method:  "POST",
        headers: { "Content-Type": "application/json" },
        body:    JSON.stringify(data),
      });
      if (status) status.textContent = res.ok ? msgDone : msgError;
      if (res.ok) form.reset();
    } catch {
      if (status) status.textContent = msgNetwork;
    }
  });
</script>
