---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { t } from "../../i18n/utils";
import { tenant } from "../../config/tenant";
import ServiceForm from "../../components/ServiceForm.astro";

export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "fr" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: string };
const tr = t(lang);
const m = tr.migration;
const currentPath = `/${lang}/migration-sharepoint`;

// Heroicons outline paths — one per benefit (same stroke style as landing page)
const benefitIcons = [
  // Folder — centralized documents
  `<path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z" />`,
  // Lock — permissions
  `<path stroke-linecap="round" stroke-linejoin="round" d="M16.5 10.5V6.75a4.5 4.5 0 10-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 002.25-2.25v-6.75a2.25 2.25 0 00-2.25-2.25H6.75a2.25 2.25 0 00-2.25 2.25v6.75a2.25 2.25 0 002.25 2.25z" />`,
  // Users — collaboration
  `<path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" />`,
  // Grid — organization
  `<path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6A2.25 2.25 0 016 3.75h2.25A2.25 2.25 0 0110.5 6v2.25a2.25 2.25 0 01-2.25 2.25H6a2.25 2.25 0 01-2.25-2.25V6zM3.75 15.75A2.25 2.25 0 016 13.5h2.25a2.25 2.25 0 012.25 2.25V18a2.25 2.25 0 01-2.25 2.25H6A2.25 2.25 0 013.75 18v-2.25zM13.5 6a2.25 2.25 0 012.25-2.25H18A2.25 2.25 0 0120.25 6v2.25A2.25 2.25 0 0118 10.5h-2.25a2.25 2.25 0 01-2.25-2.25V6zM13.5 15.75a2.25 2.25 0 012.25-2.25H18a2.25 2.25 0 012.25 2.25V18A2.25 2.25 0 0118 20.25h-2.25A2.25 2.25 0 0113.5 18v-2.25z" />`,
  // Magnifying glass — search
  `<path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 15.803a7.5 7.5 0 0010.607 0z" />`,
  // Cog — automation
  `<path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.324.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.24-.438.613-.431.992a6.759 6.759 0 010 .255c-.007.378.138.75.43.99l1.005.828c.424.35.534.954.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.57 6.57 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.28c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.02-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.992a6.932 6.932 0 010-.255c.007-.378-.138-.75-.43-.99l-1.004-.828a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.087.22-.128.332-.183.582-.495.644-.869l.214-1.281z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />`,
  // Chat bubble — communication
  `<path stroke-linecap="round" stroke-linejoin="round" d="M7.5 8.25h9m-9 3H12m-9.75 1.51c0 1.6 1.123 2.994 2.707 3.227 1.129.166 2.27.293 3.423.379.35.026.67.21.865.501L12 21l2.755-4.133a1.14 1.14 0 01.865-.501 48.172 48.172 0 003.423-.379c1.584-.233 2.707-1.626 2.707-3.228V6.741c0-1.602-1.123-2.995-2.707-3.228A48.394 48.394 0 0012 3c-2.392 0-4.744.175-7.043.513C3.373 3.746 2.25 5.14 2.25 6.741v6.018z" />`,
  // Clock — versioning
  `<path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z" />`,
  // Link — integration
  `<path stroke-linecap="round" stroke-linejoin="round" d="M13.19 8.688a4.5 4.5 0 011.242 7.244l-4.5 4.5a4.5 4.5 0 01-6.364-6.364l1.757-1.757m13.35-.622l1.757-1.757a4.5 4.5 0 00-6.364-6.364l-4.5 4.5a4.5 4.5 0 001.242 7.244" />`,
];
---

<SiteLayout title={m.title} description={m.heroDesc} lang={lang} currentPath={currentPath}>
  <style>
    .card-dark {
      background: var(--card);
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow: 0 20px 40px rgba(0,0,0,0.45), 0 4px 12px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.07);
      border-radius: 1rem;
    }
    .hover-tint {
      background: radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 62%);
      position: absolute; inset: 0; pointer-events: none; opacity: 0; transition: opacity 0.3s;
    }
    .group:hover .hover-tint { opacity: 1; }
    .icon-box {
      background: color-mix(in srgb, var(--accent) 12%, transparent);
      border: 1px solid color-mix(in srgb, var(--accent) 22%, transparent);
    }
    .focus-ring:focus { outline: none; box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 30%, transparent); }
    .pill {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
      color: color-mix(in srgb, var(--text) 88%, transparent);
      display: inline-flex; align-items: center;
      border-radius: 999px; padding: 0.25rem 0.85rem;
      font-size: 0.75rem; font-weight: 500;
    }
  </style>

  <!-- HEADER -->
  <div slot="header" class="flex flex-col items-center">
    <img src={tenant.logoSrc} alt={tenant.name} class="h-28 md:h-36 w-auto drop-shadow-lg" />
    <p class="mt-3 text-xs tracking-[0.35em] uppercase"
       style="color: color-mix(in srgb, var(--text) 55%, transparent);">{m.headerSubtitle}</p>
  </div>

  <!-- HERO -->
  <section slot="hero" class="relative max-w-4xl mx-auto px-4 text-center z-20 pt-2 pb-10">
    <div class="pointer-events-none absolute left-1/2 top-8 -translate-x-1/2 w-[65%] h-24 blur-[80px] opacity-60"
         style="background: color-mix(in srgb, var(--accent) 20%, transparent);"></div>

    <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight animate-fade-up" style="color: var(--text);">
      {m.heroTitle}
    </h1>
    <p class="mt-4 text-lg leading-relaxed soft animate-fade-up animate-fade-up-delay-1 max-w-2xl mx-auto">
      {m.heroDesc}
    </p>

    <div class="mt-6 flex flex-col sm:flex-row gap-3 justify-center animate-fade-up animate-fade-up-delay-2">
      <a href="#avantages"
         class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold transition hover:brightness-110 active:scale-95"
         style="background: var(--accent); color: #111; box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 30%, transparent);">
        {lang === "fr" ? "Voir les avantages" : "See the benefits"}
      </a>
    </div>

    <div class="mt-8 flex flex-wrap gap-2 justify-center animate-fade-up animate-fade-up-delay-3">
      {m.pills.map((p) => <span class="pill">{p}</span>)}
    </div>
  </section>

  <!-- BAND -->
  <section class="relative w-full overflow-hidden" style="background: var(--band);">
    <div class="h-[2px] w-full" style="background: var(--accent);"></div>
    <div class="h-12 w-full"
         style="background: linear-gradient(to bottom, color-mix(in srgb, var(--accent) 16%, transparent), transparent);"></div>

    <div class="relative mx-auto max-w-6xl px-4 pb-20 space-y-16">

      <!-- BENEFITS HEADER -->
      <div id="avantages" class="text-center reveal pt-4">
        <p class="text-xs uppercase tracking-[0.35em] mb-3" style="color: color-mix(in srgb, var(--accent) 85%, transparent);">
          SharePoint × Microsoft Teams
        </p>
        <h2 class="text-2xl md:text-3xl font-bold" style="color: rgba(17,17,17,0.92);">{m.benefitsTitle}</h2>
        <p class="mt-3 text-base leading-relaxed mx-auto max-w-2xl" style="color: rgba(17,17,17,0.68);">{m.benefitsDesc}</p>
      </div>

      <!-- BENEFITS GRID — 3×3 -->
      <div class="grid gap-5 md:grid-cols-3">
        {m.benefits.map((b, i) => (
          <div class="group relative overflow-hidden rounded-2xl p-6 card-dark reveal"
               style={`animation-delay: ${i * 0.06}s;`}>
            <div class="hover-tint"></div>
            <div class="relative flex items-start gap-4">
              <!-- Icon box -->
              <div class="h-11 w-11 rounded-xl icon-box flex items-center justify-center shrink-0 mt-0.5"
                   style="color: var(--accent);">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none"
                     viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"
                     set:html={benefitIcons[i]}></svg>
              </div>
              <div>
                <h3 class="text-base font-semibold" style="color: var(--accent);">{b.title}</h3>
                <p class="mt-1.5 text-sm leading-relaxed soft">{b.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>

      <!-- CTA + INLINE FORM SECTION -->
      <section id="soumission" class="pb-6">
        <div class="rounded-3xl p-8 md:p-10 card-dark overflow-hidden relative reveal">
          <div class="hover-tint" style="opacity: 0.60;"></div>
          <!-- Corner glows -->
          <div class="pointer-events-none absolute -top-20 -left-20 h-52 w-52 rounded-full blur-3xl opacity-25"
               style="background: var(--accent);"></div>
          <div class="pointer-events-none absolute -bottom-20 -right-20 h-52 w-52 rounded-full blur-3xl opacity-15"
               style="background: var(--accent);"></div>

          <div class="relative flex flex-col gap-8">
            <!-- Title + open button -->
            <div>
              <p class="text-xs uppercase tracking-[0.35em] mb-3"
                 style="color: color-mix(in srgb, var(--accent) 85%, transparent);">
                {lang === "fr" ? "Passez à l'action" : "Take action"}
              </p>
              <h2 class="text-3xl font-semibold soft">{m.ctaTitle}</h2>
              <p class="mt-2 muted">{m.ctaDesc}</p>
              <div class="mt-6">
                <button id="openFormBtn" type="button"
                        class="inline-flex items-center justify-center px-6 py-3 rounded-xl font-semibold transition hover:brightness-110 focus-ring"
                        style="background: var(--accent); color: #111; box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 30%, transparent);">
                  {m.ctaBtn}
                </button>
              </div>
            </div>

            <ServiceForm
              lang={lang}
              serviceName="Migration SharePoint"
              formId="migrationForm"
              containerId="formContainer"
              statusId="migrationStatus"
              openBtnId="openFormBtn"
              formTitle={m.formTitle}
              closeLabel={m.formCloseBtn}
            >
              <div>
                <label class="block text-sm font-semibold mb-1 soft">{tr.common.usersOpt}</label>
                <input type="number" name="migration_users" min="1"
                       class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                       style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);" />
              </div>
            </ServiceForm>
          </div>
        </div>
      </section>

    </div>
  </section>

</SiteLayout>
