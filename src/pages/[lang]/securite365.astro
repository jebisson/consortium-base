---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { t } from "../../i18n/utils";
import { tenant } from "../../config/tenant";
import ServiceForm from "../../components/ServiceForm.astro";

export const prerender = true;
export function getStaticPaths() {
  return [{ params: { lang: "fr" } }, { params: { lang: "en" } }];
}

const { lang } = Astro.params as { lang: string };
const tr = t(lang);
const s = tr.security;
const common = tr.common;

const currentPath = `/${lang}/securite365`;

const faqItems = lang === "fr" ? [
  { question: "Qu'est-ce qu'un audit de sécurité Microsoft 365 ?", answer: "Un audit évalue la configuration de votre tenant Microsoft 365 : politiques d'accès, MFA, partage de fichiers, paramètres de sécurité et score Defender. On identifie les lacunes et on priorise les correctifs selon votre réalité." },
  { question: "Est-ce que Microsoft 365 Business Standard est suffisant pour la sécurité ?", answer: "Non. Business Standard n'inclut pas les outils de sécurité avancés comme Defender for Business, la protection contre les liens malveillants ou la détection des identités compromises. Business Premium est recommandé pour les organisations qui prennent la sécurité au sérieux." },
  { question: "Qu'est-ce que la Loi 25 exige pour les OBNL et coopératives au Québec ?", answer: "La Loi 25 exige que les organisations documentent leurs pratiques de gestion des renseignements personnels, nomment un responsable de la protection, et évaluent les risques. Microsoft 365 bien configuré contribue à ces obligations, notamment avec les journaux d'audit, le chiffrement et les politiques d'accès." },
  { question: "Est-ce que le MFA est vraiment nécessaire ?", answer: "Oui. L'activation de l'authentification multifacteur (MFA) bloque plus de 99 % des attaques sur les comptes compromis selon Microsoft. C'est la mesure de sécurité la plus efficace et la plus rapide à déployer." },
  { question: "Combien de temps prend un audit de sécurité Microsoft 365 ?", answer: "Un audit complet prend généralement de quelques heures à quelques jours selon la taille de l'organisation. On remet un rapport clair avec les priorités et les recommandations concrètes." },
] : [
  { question: "What does a Microsoft 365 security audit include?", answer: "An audit reviews your Microsoft 365 tenant configuration: access policies, MFA, file sharing settings, security parameters and Defender score. We identify gaps and prioritize fixes based on your organization's reality." },
  { question: "Is Microsoft 365 Business Standard enough for security?", answer: "No. Business Standard does not include advanced security tools like Defender for Business, protection against malicious links, or compromised identity detection. Business Premium is recommended for organizations that take security seriously." },
  { question: "What does Quebec's Law 25 require for nonprofits and cooperatives?", answer: "Law 25 requires organizations to document personal information management practices, appoint a privacy officer, and assess risks. A properly configured Microsoft 365 helps meet these obligations through audit logs, encryption and access policies." },
  { question: "Is MFA really necessary?", answer: "Yes. Enabling multi-factor authentication (MFA) blocks over 99% of account compromise attacks according to Microsoft. It is the most effective and fastest security measure to deploy." },
  { question: "How long does a Microsoft 365 security audit take?", answer: "A full audit typically takes a few hours to a few days depending on organization size. We deliver a clear report with priorities and concrete recommendations." },
];
---

<SiteLayout title={s.title} description={s.heroDesc} lang={lang} currentPath={currentPath} faqItems={faqItems}>

  <style>
    .card-dark {
      background: var(--card);
      border: 1px solid rgba(255,255,255,0.06);
      box-shadow: 0 20px 40px rgba(0,0,0,0.45), 0 4px 12px rgba(0,0,0,0.25), 0 0 0 1px rgba(255,255,255,0.07);
      border-radius: 1rem;
    }
    .hover-tint {
      background: radial-gradient(circle at 18% 18%, color-mix(in srgb, var(--accent) 16%, transparent), transparent 62%);
      position: absolute; inset: 0; pointer-events: none; opacity: 0.70;
      transition: opacity 0.3s;
    }
    .icon-accent { color: var(--accent); }
    .card-icon {
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.10);
    }
    .focus-ring:focus { outline: none; box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 30%, transparent); }
  </style>

  <!-- HEADER -->
  <div slot="header" class="flex flex-col items-center">
    <img src={tenant.logoSrc} alt={tenant.name} class="h-28 md:h-36 w-auto drop-shadow-lg" fetchpriority="high" loading="eager" />
    <p class="mt-3 text-xs tracking-[0.35em] uppercase"
       style="color: color-mix(in srgb, var(--text) 55%, transparent);">{s.headerSubtitle}</p>
  </div>

  <!-- HERO -->
  <div slot="hero" class="relative max-w-4xl mx-auto px-4 text-center z-20 pt-2 pb-10">
    <div class="pointer-events-none absolute left-1/2 top-8 -translate-x-1/2 w-[65%] h-24 blur-[80px] opacity-60"
         style="background: color-mix(in srgb, var(--accent) 20%, transparent);"></div>

    <h1 class="mt-4 text-4xl md:text-5xl font-bold tracking-tight animate-fade-up" style="color: var(--text);">
      {s.heroTitle}
    </h1>
    <p class="mt-4 text-lg soft animate-fade-up animate-fade-up-delay-1">{s.heroSubtitle}</p>
    <p class="mt-3 text-sm muted animate-fade-up animate-fade-up-delay-2">{s.hoverHint}</p>
  </div>
  <!-- BACK LINK -->

  <!-- BAND -->
  <section class="relative w-full overflow-hidden" style="background: var(--band);">
    <div class="h-[2px] w-full" style="background: var(--accent);"></div>
    <div class="h-12 w-full"
         style="background: linear-gradient(to bottom, color-mix(in srgb, var(--accent) 16%, transparent), transparent);"></div>

    <div class="relative mx-auto max-w-5xl px-4 pt-6 pb-6">
      <div class="grid md:grid-cols-2 gap-6">

        <!-- Audit card -->
        <section class="group relative overflow-hidden rounded-2xl p-8 card-dark reveal">
          <div class="hover-tint"></div>
          <div class="relative">
            <div class="h-11 w-11 rounded-xl card-icon flex items-center justify-center mb-4">
              <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/>
              </svg>
            </div>
            <p class="text-xs uppercase tracking-[0.25em] muted">{s.auditLabel}</p>
            <h3 class="mt-2 text-2xl font-semibold" style="color: var(--text);">{s.auditTitle}</h3>
            <p class="mt-3 leading-relaxed soft">{s.auditDesc}</p>
            <p class="mt-3 text-sm muted italic">{s.statBanner}</p>
            <div class="mt-6">
              <button id="openAuditBtn"
                      class="px-6 py-3 rounded-xl font-semibold transition hover:brightness-110"
                      style={`background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 92%, white 8%), color-mix(in srgb, var(--accent) 72%, black 28%)); color: #111;`}>
                {s.auditBtn}
              </button>
            </div>
            <ul class="mt-6 list-disc ml-6 space-y-2 text-sm soft">
              {s.auditBullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
        </section>

        <!-- Contact card -->
        <section class="group relative overflow-hidden rounded-2xl p-8 card-dark reveal">
          <div class="hover-tint"></div>
          <div class="relative">
            <div class="h-11 w-11 rounded-xl card-icon flex items-center justify-center mb-4">
              <svg class="h-6 w-6 icon-accent" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81 19.79 19.79 0 01.01 1.18 2 2 0 012 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/>
              </svg>
            </div>
            <p class="text-xs uppercase tracking-[0.25em] muted">{s.contactLabel}</p>
            <h3 class="mt-2 text-2xl font-semibold" style="color: var(--text);">{s.contactTitle}</h3>
            <p class="mt-3 leading-relaxed soft">{s.contactDesc}</p>
            <button id="openContactBtn"
                    class="inline-flex mt-6 px-6 py-3 rounded-xl font-semibold transition hover:brightness-110"
                    style="background: rgba(255,255,255,0.06); border: 1px solid rgba(255,255,255,0.10); color: color-mix(in srgb, var(--text) 92%, transparent);">
              {s.contactBtn}
            </button>

            <ServiceForm
              lang={lang}
              serviceName="Sécurité Microsoft 365"
              formId="contactForm"
              containerId="contactFormContainer"
              statusId="contactStatus"
              openBtnId="openContactBtn"
              formTitle={s.formTitle}
              contactSource="securite365"
            >
              <div>
                <label class="block text-sm font-semibold mb-1 soft">{common.usersOpt}</label>
                <input type="number" name="contact_users" min="1" class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                       style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);" />
              </div>
              <div>
                <label class="block text-sm font-semibold mb-1 soft">{common.subject}</label>
                <select name="contact_subject" class="focus-ring w-full rounded-lg px-3 py-2.5 text-sm"
                        style="background: color-mix(in srgb, var(--text) 7%, var(--bg)); border: 1px solid var(--border); color: var(--text);">
                  {s.subjectOptions.map((opt) => (
                    <option value={opt.value}>{opt.label}</option>
                  ))}
                </select>
              </div>
            </ServiceForm>
          </div>
        </section>
      </div>
    </div>

    <!-- 14 security points -->
    <div class="relative mx-auto max-w-5xl px-4 pt-8 pb-24 grid gap-6">
      {s.points.map((p, i) => (
        <section class="group relative overflow-hidden rounded-2xl p-6 card-dark transition-all duration-300 hover:-translate-y-1 reveal">
          <div class="hover-tint"></div>
          <div class="relative flex items-start gap-5">
            <div class="shrink-0">
              <div class="grid place-items-center w-14 h-14 rounded-full"
                   style={`background: rgba(0,0,0,0.25); border: 2px solid color-mix(in srgb, var(--accent) 35%, transparent); box-shadow: 0 0 18px color-mix(in srgb, var(--accent) 18%, transparent);`}>
                <span class="text-2xl font-extrabold" style="color: var(--accent);">{i + 1}</span>
              </div>
            </div>
            <div class="flex-1">
              <h3 class="text-lg md:text-xl font-semibold" style="color: var(--text);">{p.t}</h3>
              <div class="mt-3 space-y-3 opacity-0 max-h-0 overflow-hidden transition-all duration-300 group-hover:opacity-100 group-hover:max-h-[900px]">
                {p.lead.map((para) => (
                  <p class="text-[15px] leading-relaxed soft">{para}</p>
                ))}
              </div>
            </div>
          </div>
        </section>
      ))}
    </div>
  </section>


</SiteLayout>

<script>
  // Audit button: pre-fill subject then open the same panel
  document.getElementById("openAuditBtn")?.addEventListener("click", () => {
    const panel = document.getElementById("contactFormContainer");
    const subject = document.querySelector<HTMLSelectElement>('#contactForm select[name="contact_subject"]');
    if (subject) subject.value = "Audit 365";
    if (panel) {
      panel.style.maxHeight = panel.scrollHeight + "px";
      panel.style.opacity = "1";
      panel.scrollIntoView({ behavior: "smooth", block: "start" });
    }
  });
</script>
